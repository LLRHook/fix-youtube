{
  "manifest_version": 3,
  "name": "Fix YouTube",
  "version": "0.1.0",
  "description": "Removes Shorts and makes Subscriptions your default YouTube landing page.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.youtube.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "redirect_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
