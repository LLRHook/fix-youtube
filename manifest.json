{
  "manifest_version": 3,
  "name": "Fix YouTube",
  "version": "0.2.0",
  "description": "Removes Shorts, redirects to Subscriptions, hides distractions, and gives you control over your YouTube experience.",
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "redirect_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Toggle suggested videos sidebar"
    },
    "toggle-subs-only": {
      "suggested_key": { "default": "Alt+F" },
      "description": "Toggle subscriptions-only filter"
    },
    "toggle-timer": {
      "suggested_key": { "default": "Alt+T" },
      "description": "Toggle daily usage timer"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
